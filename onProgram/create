const api = require('../../utils/api')

Page({
  data: {
    keyword: '',
    ingredients: [],
    loading: true,
    page: 1,
    hasMore: true
  },

  onLoad() {
    this.loadIngredients()
  },

  async loadIngredients(reset = true) {
    if (reset) {
      this.setData({ page: 1, ingredients: [], hasMore: true })
    }
    
    this.setData({ loading: true })
    
    try {
      const params = {
        page: this.data.page,
        page_size: 20
      }
      if (this.data.keyword) params.q = this.data.keyword
      
      const result = await api.getIngredients(params)
      const items = result.items || result || []
      
      this.setData({
        ingredients: reset ? items : [...this.data.ingredients, ...items],
        hasMore: items.length >= 20,
        loading: false
      })
    } catch (err) {
      console.error('加载成分列表失败:', err)
      this.setData({ loading: false })
    }
  },

  onInput(e) {
    this.setData({ keyword: e.detail.value })
  },

  onSearch() {
    this.loadIngredients()
  },

  onClear() {
    this.setData({ keyword: '' })
    this.loadIngredients()
  },

  onIngredientTap(e) {
    const id = e.currentTarget.dataset.id
    wx.navigateTo({
      url: \`/pages/ingredient/detail?id=\${id}\`
    })
  },

  onLoadMore() {
    if (this.data.hasMore && !this.data.loading) {
      this.setData({ page: this.data.page + 1 })
      this.loadIngredients(false)
    }
  },

  onReachBottom() {
    this.onLoadMore()
  }
})`)

