const api = require('../../utils/api')

Page({
  data: {
    breeds: [],
    loading: true,
    activeTab: 'dog', // dog / cat
    page: 1,
    hasMore: true
  },

  onLoad() {
    this.loadBreeds()
  },

  async loadBreeds(reset = true) {
    if (reset) {
      this.setData({ page: 1, breeds: [], hasMore: true })
    }
    
    this.setData({ loading: true })
    
    try {
      const params = {
        page: this.data.page,
        page_size: 20,
        type: this.data.activeTab
      }
      
      const result = await api.getBreeds(params)
      const items = result.items || result || []
      
      this.setData({
        breeds: reset ? items : [...this.data.breeds, ...items],
        hasMore: items.length >= 20,
        loading: false
      })
    } catch (err) {
      console.error('加载品种列表失败:', err)
      this.setData({ loading: false })
    }
  },

  onTabChange(e) {
    const tab = e.currentTarget.dataset.tab
    this.setData({ activeTab: tab })
    this.loadBreeds()
  },

  onBreedTap(e) {
    const id = e.currentTarget.dataset.id
    wx.navigateTo({
      url: \`/pages/breed/detail?id=\${id}\`
    })
  },

  onLoadMore() {
    if (this.data.hasMore && !this.data.loading) {
      this.setData({ page: this.data.page + 1 })
      this.loadBreeds(false)
    }
  },

  onReachBottom() {
    this.onLoadMore()
  }
})`)

