/* pages/search/search.wxss */

.page-search {
  min-height: 100vh;
  background: var(--bg-color);
}

/* 搜索头部 */
.search-header {
  background: var(--white);
  padding: 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-bar {
  display: flex;
  align-items: center;
  background: var(--bg-color);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-color);
}

.clear-btn {
  font-size: 28rpx;
  color: var(--text-light);
  padding: 10rpx;
}

/* 筛选区域 */
.filter-section {
  background: var(--white);
  margin-bottom: 20rpx;
}

.filter-row {
  white-space: nowrap;
  padding: 20rpx;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background: var(--bg-color);
  color: var(--text-secondary);
}

.filter-tag.active {
  background: var(--primary-light);
  color: var(--primary-color);
}

.sort-row {
  display: flex;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.sort-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 12rpx 0;
}

.sort-item.active {
  color: var(--primary-color);
  font-weight: 500;
}

/* 结果区域 */
.result-section {
  padding: 0 20rpx;
}

/* 加载中 */
.loading {
  padding: 60rpx;
  text-align: center;
}

.loading-text {
  color: var(--text-light);
  font-size: 28rpx;
}

/* 产品列表 */
.product-list {
  background: var(--white);
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.product-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.product-card:last-child {
  border-bottom: none;
}

.product-card .image {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.product-card .image image {
  width: 100%;
  height: 100%;
}

.product-card .info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.product-card .name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card .brand {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.product-card .desc {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card .meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.product-card .score {
  font-size: 28rpx;
  font-weight: bold;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
  color: var(--text-light);
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  color: var(--text-light);
  font-size: 30rpx;
  margin-bottom: 10rpx;
}

.empty-state .sub-text {
  color: var(--text-light);
  font-size: 24rpx;
}