/* pages/ingredient/detail.wxss */

.page-detail {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 20rpx;
}

.header-card {
  text-align: center;
}

.ingredient-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 12rpx;
}

.ingredient-alias {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.risk-badge {
  display: inline-block;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 4rpx;
}

.risk-1 { background: #e8f8ee; color: #07c160; }
.risk-2 { background: #fff8e6; color: #ff9500; }
.risk-3 { background: #fff0e6; color: #ff6b00; }
.risk-4, .risk-5 { background: #ffebeb; color: #fa5151; }

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.desc-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.product-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.product-item:last-child { border-bottom: none; }

.product-name {
  font-size: 28rpx;
  color: var(--text-color);
}

.product-brand {
  font-size: 24rpx;
  color: var(--text-light);
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  color: var(--text-light);
  font-size: 28rpx;
}