/* pages/index/index.wxss */

.page-index {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--white);
  margin: 20rpx;
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-color);
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 20rpx;
  background: var(--white);
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.category-item .icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.category-item .text {
  font-size: 24rpx;
  color: var(--text-color);
}

/* 章节 */
.section {
  background: var(--white);
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.section-title .title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.section-title .more {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 加载中 */
.loading {
  padding: 60rpx;
  text-align: center;
}

.loading-text {
  color: var(--text-light);
  font-size: 28rpx;
}

/* 产品列表 */
.product-list {
  padding: 0 24rpx 24rpx;
}

.product-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.product-card:last-child {
  border-bottom: none;
}

.product-card .image {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.product-card .image image {
  width: 100%;
  height: 100%;
}

.product-card .info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-card .name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card .brand {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.product-card .meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-card .score {
  font-size: 28rpx;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  color: var(--text-light);
  font-size: 28rpx;
}