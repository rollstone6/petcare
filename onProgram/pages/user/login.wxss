/* pages/user/login.wxss */

.page-login {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 40rpx 30rpx;
}

.login-header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.login-header .logo {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.login-header .title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.login-form {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item .label {
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
  display: block;
}

.form-item .input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-color);
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 8rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.toggle-link {
  text-align: center;
  font-size: 26rpx;
  color: var(--primary-color);
  margin-top: 24rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider .line {
  flex: 1;
  height: 1rpx;
  background: var(--border-color);
}

.divider .text {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.wechat-login {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.wechat-login .icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}