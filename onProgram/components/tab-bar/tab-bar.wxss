.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-inner {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
}

.tab-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.tab-item.active .tab-label {
  color: #07c160;
  font-weight: 500;
}