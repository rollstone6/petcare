<view class="tab-bar">
  <view class="tab-bar-inner">
    <view
      wx:for="{{tabs}}"
      wx:key="path"
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onTabTap"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-label">{{item.label}}</text>
    </view>
  </view>
</view>